<div class="bs-row bs-align-items-center bs-border-bottom bs-g-0 nested-fields" data-search-target="item" data-name="<%= @group_name %>" data-selected-parent-selector="<%= @selector_group_type %>" data-id="<%= @group_id %>" data-name-attr="<%= @name %>">
    <!-- Used to update selected groups for device admin -->
    <div data-edit-admin-form-target="selectedGroup" data-id="<%= @group_id %>" class="bs-visually-hidden bs-pe-none">
        <%= @group_name %>
    </div>
    <!-- End -->
    <input  data-multi-select-groups-checkbox-target="selected" data-id="checkbox-<%= @group_dom_id %>" data-choose-groups-target="selected" type="hidden" data-name="<%= @group_name %>" name="<%= @name %>" value="<%= @group_id %>">
    <div class="bs-col-7 bs-mt-3">
        <div class="bs-form-check bs-ps-4">
            <label class="bs-form-check-label bs-text-body bs-text-truncate" data-controller="tooltip"> 
                <% if @has_pareng_group %>
                    <i class="zmdi zmdi-arrow-split zmdi-hc-rotate-180 zmdi-hc-1x bs-me-2 bs-fs-5" data-bs-toggle="bs-tooltip" data-bs-placement="top" data-bs-title="Sub Group"></i>
                <% else %>
                    <i class="zmdi zmdi-circle bs-me-2 bs-fs-6" data-bs-toggle="bs-tooltip" data-bs-placement="top" data-bs-title="Main Group"></i>
                <% end %>
                <% if @hierarchical_name.present? %>
                    <span data-bs-toggle="bs-tooltip" data-bs-placement="top" data-bs-title="<%= @hierarchical_name %>">
                        <%= @group_name %>
                    </span>
                <% else %>
                    <%= @group_name %>
                <% end %>
            </label>
        </div>
    </div>
    <div class="bs-col-3 bs-text-center">
        <% if count? %>
            <%= count %>
        <% end %>
    </div>
    <div data-action="click->choose-groups#removeAssociation" data-choose-groups-id-param="template-<%= @group_dom_id %>" class="bs-btn bs-btn-link bs-p-0 bs-col-2 bs-text-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-x-circle bs-text-danger bs-align-middle"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
    </div>
</div>