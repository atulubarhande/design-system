<%= content_tag :div, data: {
        controller: "contact-actions",
        identifier: "contact-#{dom_id(contact)}",
        add_contact_target: "addedContact",
        search_target: "item",
        name: contact.name + "#{@numbers&.first&.contact_number}"
    }, class: "bs-row bs-align-items-center bs-checkbox-row bs-border-bottom bs-g-0 #{@hidden ? "bs-d-none" : "visible-contact"}" do %>

    <%= hidden_field_tag "config[config_contact_mappings_attributes][][id]", @id if @id.present? && @is_new == "false" %>
    <%= hidden_field_tag "config[config_contact_mappings_attributes][][contact_id]", @contact_id %>
    <%= hidden_field_tag "config[config_contact_mappings_attributes][][action]", @action, data: { contact_actions_target: "actionInput" } %>
    <%= hidden_field_tag "config[config_contact_mappings_attributes][][visible]", @visible, data: { contact_actions_target: "visibleInput" } %>
    <div class="bs-col-4 bs-mt-3">
        <div class="bs-form-check bs-ps-5">
            <%= check_box_tag "contact_ids", "added-#{@contact_id}", false, id: @contact_id, data: {
                action: "select-all#updateSelectAllState add-contact#handleTargetIndeterminate contact-actions#onChange",
                id: "addable-#{dom_id(contact)}",
                contact_id: @id,
                remove_id: "contact-#{dom_id(contact)}",
                select_all_target: @hidden ? "REPLACE_WITH_CHECKBOX" : "checkbox",
                add_contact_target: "targetCheckbox" }, class: "bs-form-check-input" %>
            <%= label_tag @contact_id, class: "bs-form-check-label bs-text-body-secondary" do %>
                <span title="<%= contact.name %>"><%= (contact.name.length > 20) ? contact.name.slice(0, 20)+'...' : contact.name %></span>
                <br>
                <%= content_tag :div, @numbers&.first&.contact_number, class: "bs-badge bs-bg-secondary-subtle bs-text-secondary-emphasis bs-fs-6 bs-fw-normal bs-text-truncate", title: @numbers&.first&.contact_number if @numbers.present? %> 
                <%= content_tag :div, "+ #{@numbers.length - 1}", class: "bs-badge bs-bg-secondary-subtle bs-text-secondary-emphasis bs-fs-6 bs-fw-normal bs-text-truncate" if @numbers.length > 1 %>
            <% end %>
        </div>
    </div>
    <div class="bs-col-2 bs-d-flex bs-justify-content-center">
        <%= sf "BsToggle", action: "contact-actions#onActionChange", data: "data-contact-actions-target=incoming data-add-contact-target=incoming data-checked=false", checked: @incoming_active, name: "", label: "", disabled: contact.contact_type == "ussd" %>
    </div>
    <div class="bs-col-2 bs-d-flex bs-justify-content-center">
        <%= sf "BsToggle", action: "contact-actions#onActionChange", data: "data-contact-actions-target=outgoing data-checked=false", checked: @outgoing_active, name: "", label: "" %>
    </div>
    <div class="bs-col-2 bs-d-flex bs-justify-content-center">
        <%= sf "BsToggle", action: "contact-actions#onVisibilityChange", data: "data-contact-actions-target=visible data-checked=false", checked: @visible, name: "", label: "", disabled: contact.contact_type == "starts_with" %>
    </div>
    <div class="bs-col-2 bs-d-flex bs-justify-content-center bs-text-danger">
        <%= content_tag :div, data: {
            add_contact_target: "removeButton",
            action: "click->add-contact#removeContact",
            add_contact_id_param: "addable-#{dom_id(contact)}",
            add_contact_remove_id_param: "contact-#{dom_id(contact)}"
            }, :class => "bs-btn bs-btn-link" do %>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#F44336" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-trash"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
        <% end %>
    </div>
<% end %>
