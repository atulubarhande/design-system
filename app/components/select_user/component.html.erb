<div data-controller="autocomplete select-user"
    data-autocomplete-hidden-class="bs-d-none"
    data-select-user-hidden-class="bs-d-none"
    data-autocomplete-active-class="bs-active">

    <%= hidden_field_tag "billing_contact[#{@name}][]", selected_user&.id, data: { select_user_target: "userField" } %>

    <div class="bs-d-flex bs-align-items-center bs-justify-content-between">
        <div class="bs-dropdown bs-w-100" data-select-user-target="dropdown">
            <button class="bs-btn bs-btn-outline-secondary bs-dropdown-toggle bs-w-100 bs-d-flex bs-align-items-center bs-justify-content-between" type="button" id="auto-complete" data-bs-toggle="dropdown" aria-expanded="false">
                    <div data-autocomplete-target="selected" class="bs-text-truncate"><%= selected_user_name %></div>
            </button>
            <ul class="bs-dropdown-menu bs-shadow bs-w-100" aria-labelledby="auto-complete">
                <div class="bs-position-relative bs-flex-grow-1 bs-m-3">
                    <div class="bs-position-absolute bs-top-0 bs-end-0 bs-bottom-0 bs-start-0 bs-ps-3 bs-d-flex bs-align-items-center" style="pointer-events: none;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-search"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                    </div>
                    <input
                        data-select-user-target="searchInput"
                        data-action="select-user#searchUsers" type="text"
                        placeholder="<%= t('common.search') %>"
                        class="bs-d-flex bs-form-control bs-ps-5"
                    />
                </div>
                <div class="bs-overflow-auto bs-scroll-sm" style="max-height: 280px;">
                    <% users.each do |user| %>
                        <li>
                            <%= button_tag(type: "button", value: user.id, class: "bs-dropdown-item bs-py-2 bs-text-truncate #{"bs-active" if selected_user&.id.to_i == user.id.to_i}", target: "current_user",
                                data: { select_user_target: "user", select_user_role_id_param: user.id, select_user_contact_type_param: name, name: "#{user.name} ( #{user.email} )", action: "autocomplete#onChange select-user#onUserChange", autocomplete_target: "option" }) do %>
                                <%= "#{user.name} ( #{user.email} )" %>
                            <% end %>
                        </li>
                    <% end %>
                    <%= content_tag :div, t('common.no_result'), data: { select_user_target: "empty" }, class: "bs-alert bs-alert-warning bs-d-none bs-text-center bs-m-3" %>
                </div>
            </ul>
        </div>
    </div>

</div>
