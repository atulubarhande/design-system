<%= content_tag :div, class: @container_classes do %>
    <% if custom_label || @label %>
        <%= label_tag @name, class: "bs-form-label bs-fs-6 bs-text-body-secondary bs-my-3 #{@label_classes}" do %>
            <% if custom_label? %>
                <%= custom_label %>
            <% else %>
                <%= raw @label %>
            <% end %>
        <% end %>
    <% end %>
    <%= select_tag @name, options_for_select(@list, :selected => @selected, disabled: @disabled_options), { :class =>"bs-form-select bs-scroll-sm #{@classes}", :id => @id, data: custom_data, prompt: @has_null_option ? @promt_message : nil, required: @required, disabled: @disabled, multiple: @multiple }.merge(set_id) %>
<% end %>
