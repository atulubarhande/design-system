<%= button_tag({ data: @data, :class => button_variant_class} ) do %>
    <% if loading_icon? %>
        <%= loading_icon %>
    <% end %>
    <% if leading_icon? %>
        <%= leading_icon %>
    <% end %>
    <%= @label %>
    <% if trailing_icon? %>
        <%= trailing_icon %>
    <% end %>
<% end %>
