            </svg>'.html_safe
        when 'ios', 'prosurf'
            if (@device_mode == "byod" || @device_mode == "kiosk" || @device_mode == nil)
                image_tag  asset_path('common-assets/ios-supervised-dark.svg'), width:"18px", height: "18px", class: "bs-d-inline-block bs-align-middle"
            elsif (@device_mode == "user_enrolled")
                image_tag  asset_path('common-assets/ios-managed-dark.svg'), width:"18px", height: "18px", class: "bs-d-inline-block bs-align-middle"
            else
                image_tag  asset_path("v2/icons/ios-app-icon-dark.svg"), width:"18px", height: "18px", class: "bs-d-inline-block bs-align-middle"
            end
        when 'ios_dark'
            image_tag  asset_path("v2/icons/ios-app-icon-dark.svg"), width:"18px", height: "18px", class: "bs-d-inline-block bs-align-middle"
        when 'mac_dark'
            image_tag  asset_path("v2/icons/macos-app-icon-dark.svg"), width:"18px", height: "18px", class: "bs-d-inline-block bs-align-middle"
        when 'apple_tv'
            image_tag  asset_path("v2/icons/apple-tv-icon.svg"), width:"18px", height: "18px", class: "bs-d-inline-block bs-align-middle"
        when 'tvos', 'apple_tv_dark'
            image_tag  asset_path("v2/icons/apple-tv-icon-dark.png"), width:"18px", height: "18px", class: "bs-d-inline-block bs-align-middle"
        end
    %>
<% end %>
