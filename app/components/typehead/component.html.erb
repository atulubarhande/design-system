<%= content_tag :div, data: { controller: "typehead" } do  %>
    <% if @has_textarea %>
        <%= text_area_tag @name, @html_content, rows: 3, id: @id, data: @data.merge(action: "typehead#onChange #{@action}",
            typehead_target: "textarea"), placeholder: @placeholder, class: "bs-form-control bs-fs-5 bs-mb-2 bs-scroll-sm #{@classes}",
            disabled: @disabled, required: @required
        %>
    <% else %>
        <%= text_field_tag @name, @html_content, id: @id, data: @data.merge(action: "typehead#onChange #{@action}",
            typehead_target:"textarea"), placeholder: @placeholder, class: "bs-form-control bs-mb-3 bs-scroll-sm #{@classes}",
            disabled: @disabled, required: @required
        %>
    <% end %>
    <% if @has_devices || @has_groups  %>
        <%= turbo_frame_tag "user_custom_fields_options", src: custom_fields_options_v3_user_custom_fields_path(default: true), loading: :lazy %>
    <% end %>
    <% if @has_users %>
        <%= turbo_frame_tag "dashboard_user_fields", src: v3_dashboard_user_fields_path(user_field_options), loading: :lazy %>
    <% end %>
<% end %>
