<%= turbo_frame_tag dom_id(device), class: "bs-device-frame-item" do %>
    <template id="template-<%= dom_id(device) %>">
        <div class="bs-row bs-align-items-center bs-border-bottom bs-g-0 nested-fields" data-selected-parent-selector="" data-search-target="item" data-id="<%= device.id %>" data-name="<%= device_name %>" data-name-attr="">
            <input data-multi-select-groups-checkbox-target="selected" data-id="checkbox-<%= dom_id(device) %>" data-choose-groups-target="selected" type="hidden" data-name="<%= device_name %>" name="<%= @name_attr %>" value="<%= device.id %>">
            <div class="bs-col-7 bs-mt-3">
                <div class="bs-form-check bs-ps-4">
                    <label class="bs-form-check-label bs-text-body bs-text-truncate"> 
                        <%= device_name %>
                    </label>
                </div>
            </div>
            <div class="bs-col-3 bs-text-center">
              <%= device&.os_version.present? ? device&.os_version : '' %>
            </div>
            <div data-action="click->choose-groups#removeAssociation" data-choose-groups-id-param="template-<%= dom_id(device) %>" class="bs-btn bs-btn-link bs-p-0 bs-col-2 bs-text-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-x-circle bs-text-danger bs-align-middle"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
            </div>
        </div>
    </template>
    <div class="bs-row bs-align-items-center bs-checkbox-row bs-border-bottom bs-g-0">
        <div class="bs-col-7 bs-mt-3">
            <% if @select_multiple %>
                <div class="bs-form-check bs-ps-5">
                    <%= check_box_tag "", device.id,
                        params[:select_all].present? && (params[:select_all] == "true") || params[:select_all].present? && (params[:select_all] == "true"),
                        id: "checkbox-#{dom_id(device)}",
                        data: {
                            action: "multi-select-groups-checkbox#updateSelectAllState",
                            id: "template-#{dom_id(device)}",
                            multi_select_groups_checkbox_target: "checkbox",
                            choose_groups_target: "checkbox"
                        },
                        disabled: params[:selected].present? && (params[:selected].include? device.id.to_s),
                        class: "bs-form-check-input" %>
                    <label for="<%= "checkbox-#{dom_id(device)}" %>" class="bs-form-check-label bs-text-body bs-text-truncate"> 
                        <%= device_name %>
                    </label>

                </div>
            <% else %>
                <div class="bs-d-flex bs-align-items-center bs-ps-3 bs-mb-3">
                    Icon
                    <div
                        data-multi-select-groups-checkbox-target="checkbox"
                        id="checkbox-<%= dom_id(device) %>"
                        data-choose-groups-target="checkbox"
                        data-id="template-<%= dom_id(device) %>"> 
                        <%= device_name %>
                    </div>
                </div>
            <% end %>
        </div>
        <div class="bs-col-3 bs-text-center">
            <% if device[:app_version_name].present? %>
                <%= device[:app_version_name] %>
            <% else %>
                <%= device[:os_version] %>
            <% end %>
        </div>
        <div class="bs-col-2 bs-text-center">
            <%= content_tag :div, data: { choose_groups_target: "addButton", action: "click->choose-groups#addAssociation", choose_groups_id_param: "template-#{dom_id(device)}" }, :class => "bs-btn bs-btn-link", title: t("common.add") do %>
                <i class="zmdi zmdi-mail-send zmdi-hc-1x bs-align-middle"></i>
            <% end %>
        </div>
    </div>
<% end %>
