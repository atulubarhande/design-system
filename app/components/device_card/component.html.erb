                    <% elsif device&.pending_os_update_available? %>
                        <%= content_tag :a, class: "automation_view_updates bs-btn bs-btn-primary", data: { device_details_device_id_param: @device&.id, device_details_device_name_param: @device&.name, device_details_event_id_param: "select-android-patch-management", action: "device-details#redirectToOsUpdate"  } do %>
                            <%= t("devices.os_updates.view_updates") %>
                        <% end %>
                    <% else %>
                        <%= button_tag({data: { bs_toggle: "modal", bs_target: "#no-pending-updates-modal" }, class: "automation_view_updates bs-btn bs-btn-primary"}) do %>
                            <%= t("devices.os_updates.view_updates") %>
                        <% end %>
                    <% end %>
                <% end %>
            <% end %>
        </div>
    <% end %>
<% end %>
