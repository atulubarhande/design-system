                            <i class="zmdi zmdi-smartphone"></i>
                        <% end %>
                        <% if device&.byod? %>
                            <%= t("devices.byod_mode") || t("common.na") %>
                        <% end %>
                        <% if device&.kiosk? || device&.mode.nil? %>
                            <%= t("devices.kiosk_mode") || t("common.na") %>
                        <% end %>
                    <% end %>
                </div>
                <!--
                ## Need to check conditions in Angular
                <div class="bs-col-xs-12 bs-col-sm-6 bs-col-md-6">
                    <%= sf "ListItem", title: t("devices.battery") do |c| %>
                        <% c.with_icon(auto_height: true, bg_class: icon_class) do |c| %>
                            <% if !device.charging %>
                                <i class="zmdi zmdi-battery"></i>
                            <% end %>
                            <% if device.charging %>
                                <i class="zmdi zmdi-battery-charging"></i>
                            <% end %>
                        <% end %>
                        <%= device&.battery_status || t("common.na") %>
                    <% end %>
                </div>
                -->
                <div class="bs-col-xs-12 bs-col-sm-6 bs-col-md-6">
                    <%= sf "ListItem", title: t("devices.build_version") do |c| %>
                        <% c.with_icon(auto_height: true, bg_class: icon_class) do |c| %>
                            <i class="zmdi zmdi-network"></i>
                        <% end %>
                        <%= device&.build_version || t("common.na") %>
                    <% end %>
                </div>
                <div class="bs-col-xs-12 bs-col-sm-6 bs-col-md-6">
                    <%= sf "ListItem", title: t("devices.wifi_mac") do |c| %>
                        <% c.with_icon(auto_height: true, bg_class: icon_class) do |c| %>
                            <i class="zmdi zmdi-portable-wifi"></i>
                        <% end %>
                        <%= device&.wifi_mac_address || t("common.na") %>
                    <% end %>
                </div>
                <div class="bs-col-xs-12 bs-col-sm-6 bs-col-md-6">
                    <%= sf "ListItem", title: t("v2.licenses.col_name") do |c| %>
                        <% c.with_icon(auto_height: true, bg_class: icon_class) do |c| %>
                            <i class="zmdi zmdi-time-interval"></i>
                        <% end %>
                        <%= device&.status || t("common.na") %>
                    <% end %>
                </div>
                <div class="bs-col-xs-12 bs-col-sm-6 bs-col-md-6">
                    <%= sf "ListItem", title: t("devices.device_encrypted") do |c| %>
                        <% c.with_icon(auto_height: true, bg_class: icon_class) do |c| %>
                            <i class="zmdi zmdi-account"></i>
                        <% end %>
                        <%= format_enable_disable_info(device&.fde_enabled) %>
                    <% end %>
                </div>
                <div class="bs-col-xs-12 bs-col-sm-6 bs-col-md-6">
                    <%= sf "ListItem", title: t("devices.managed_user") do |c| %>
                        <% c.with_icon(auto_height: true, bg_class: icon_class) do |c| %>
                            <i class="zmdi zmdi-account"></i>
                        <% end %>
                        <%= device.becomes(MacDevice).user_long_name || t("common.na") %>
                    <% end %>
                </div>
                <div class="bs-col-xs-12 bs-col-sm-6 bs-col-md-6">
                    <%= sf "ListItem", title: t("devices.host_name") do |c| %>
                        <% c.with_icon(auto_height: true, bg_class: icon_class) do |c| %>
                            <i class="zmdi zmdi-account"></i>
                        <% end %>
                        <%= device&.host_name || t("common.na") %>
                    <% end %>
                </div>
                <div class="bs-col-xs-12 bs-col-sm-6 bs-col-md-6">
                    <%= sf "ListItem", title: t("devices.os_updates.enforced_os_update") do |c| %>
                        <% c.with_icon(auto_height: true, bg_class: icon_class) do |c| %>
                            <i class="zmdi zmdi-smartphone"></i>
                        <% end %>

                        <% enforced_update = @device&.enforced_apple_os_update %>
                        <% value =
                            if @device.macos? && enforced_update.present? && !enforced_update.status_installed?
                            t(
                                'devices.os_updates.enforced_os_update_state',
                                os_version: enforced_update&.os_update&.version,
                                time: enforced_update&.enforced_at&.in_time_zone(@device.timezone.presence || current_user.preferred_timezone)&.strftime('%d-%b-%Y %I:%M %p')
                            )
                            else
                            t('common.na')
                            end
                        %>

                        <small title="<%= value %>" class="bs-text-truncate">
                        <%= value %>
                        </small>

                        <%= button_tag({data: { bs_toggle: "modal", bs_target: "#enforced-os-update-modal" }, class: "bs-btn bs-btn-outline-primary"}) do %>
                            <i class="zmdi zmdi-info"></i>
                        <% end %>
                    <% end %>
                </div>
                <% unless read_only_access('Device-ReadOnly') %>
                    <div class="bs-col-xs-12 bs-col-sm-6 bs-col-md-6">
                        <%= sf "ListItem", title: t("devices.find_mac_pin") do |c| %>
                            <% c.with_icon(auto_height: true, bg_class: icon_class) do |c| %>
                                <i class="zmdi zmdi-key"></i>
                            <% end %>
                            <small> <%= device&.apple_device_detail&.mac_pin %> </small>
                            <%= button_to device_security_pins_path(device), method: :get, data: { turbo_frame: "security_pins" }, class: "automation_view_security_pins automation_view_security_pins bs-btn bs-btn-outline-primary bs-p-2 bs-pe-3" do %>
                                <% if device&.screen_locked %>
                                    <i class="m-l-5 zmdi zmdi-lock c-red"></i>
                                <% end %>
                                <i class="m-l-5 zmdi zmdi-time"></i>
                            <% end %>
                        <% end %>
                    </div>
                <% end %>
                <div class="bs-col-xs-12 bs-col-sm-6 bs-col-md-6">
                    <%= sf "ListItem", title: t("devices.compliance_policy_group") do |c| %>
                        <% c.with_icon(auto_height: true, bg_class: icon_class) do |c| %>
                            <i class="zmdi zmdi-account"></i>
                        <% end %>
                        <%= device&.compliance_policy_group&.name || t("common.na") %>
                    <% end %>
                </div>
                <% unless read_only_access('Device-ReadOnly') %>
                    <% if !owner&.user_subscription&.allow_os_update_management_for_macos %>
                        <%= sf "UpgradePlan", current_user: current_user, classes: " bs-w-auto bs-d-flex bs-align-items-center" do |c| %>
                            <% c.with_button do %>
                                <div class="bs-btn bs-btn-primary w-100">
                                    <%= t("devices.os_updates.view_updates") %>
                                </div>
                            <% end %>
                        <% end %>
                    <% else %>
                        <%= content_tag :a, class: "bs-btn bs-btn-primary bs-w-auto bs-d-flex bs-align-items-center", data: { device_details_device_id_param: @device&.id, device_details_device_name_param: @device&.name, device_details_event_id_param: "select-mac-os-update", action: "device-details#redirectToOsUpdate"  } do %>
                            <%= t("devices.os_updates.view_updates") %>
                        <% end %>
                    <% end %>
                <% end %>
            <% end %>
            <% if device.os_type == 'windows' %>
                <% if device&.byod? %>
                    <div class="bs-col-xs-12 bs-col-sm-6 bs-col-md-6">
                        <%= sf "ListItem", title: t("common.device_profile") do |c| %>
                            <% c.with_icon(auto_height: true, bg_class: icon_class) do |c| %>
                                <i class="zmdi zmdi-collection-case-play"></i>
                            <% end %>
                            <%= device&.device_profile&.name || t("devices.no_profile_msg") %>
                        <% end %>
                    </div>
                <% end %>
                <% unless device&.byod? %>
                    <div class="bs-col-xs-12 bs-col-sm-6 bs-col-md-6">
                        <%= sf "ListItem", title: group_title do |c| %>
                            <% c.with_icon(auto_height: true, bg_class: icon_class) do |c| %>
                                <i class="zmdi zmdi-devices"></i>
                            <% end %>
                            <%= group_name %>
                        <% end %>
                    </div>
                <% end %>
                <div class="bs-col-xs-12 bs-col-sm-6 bs-col-md-6">
                    <%= sf "ListItem", title: t("windows.mobilock_agent_version") do |c| %>
                        <% c.with_icon(auto_height: true, bg_class: icon_class) do |c| %>
                            <i class="zmdi zmdi-lock-outline"></i>
                        <% end %>
                        <%= device&.app_version_name || I18n.t("devices.not_installed") %>
                    <% end %>
                </div>
                <div class="bs-col-xs-12 bs-col-sm-6 bs-col-md-6">
                    <%= sf "ListItem", title: t("windows.manufacturer") do |c| %>
                        <% c.with_icon(auto_height: true, bg_class: icon_class) do |c| %>
                            <i class="zmdi zmdi-desktop-windows"></i>
                        <% end %>
                        <%= device&.make || I18n.t("common.na") %>
                    <% end %>
                </div>
                <div class="bs-col-xs-12 bs-col-sm-6 bs-col-md-6">
                    <%= sf "ListItem", title: t("devices.battery") do |c| %>
                        <% c.with_icon(auto_height: true, bg_class: icon_class) do |c| %>
                            <% if !device&.charging %>
                                <i class="zmdi zmdi-battery"></i>

                            <% end %>
                            <% if device&.charging %>
                                <i class="zmdi zmdi-battery-charging"></i>
                            <% end %>
                        <% end %>
                        <%= batter_status %>
                    <% end %>
                </div>
                <div class="bs-col-xs-12 bs-col-sm-6 bs-col-md-6">
                    <%= sf "ListItem", title: t("emm_ios.ios_dep.model") do |c| %>
                        <% c.with_icon(auto_height: true, bg_class: icon_class) do |c| %>
                            <i class="zmdi zmdi-smartphone"></i>
                        <% end %>
                        <%= device&.model || I18n.t("common.na") %>
                    <% end %>
                </div>
                <div class="bs-col-xs-12 bs-col-sm-6 bs-col-md-6">
                    <%= sf "ListItem", title: t("v2.licenses.col_name") do |c| %>
                        <% c.with_icon(auto_height: true, bg_class: icon_class) do |c| %>
                            <i class="zmdi zmdi-time-interval"></i>
                        <% end %>
                        <%= device&.status || I18n.t("common.na") %>
                    <% end %>
                </div>
                <div class="bs-col-xs-12 bs-col-sm-6 bs-col-md-6">
                    <%= sf "ListItem", title: t("devices.os_version") do |c| %>
                        <% c.with_icon(auto_height: true, bg_class: icon_class) do |c| %>
                            <i class="zmdi zmdi-laptop"></i>
                        <% end %>
                        <%= device&.os_version || I18n.t("common.na") %>
                    <% end %>
                </div>
                <div class="bs-col-xs-12 bs-col-sm-6 bs-col-md-6">
                    <%= sf "ListItem", title: t("devices.onboarding_email") do |c| %>
                        <% c.with_icon(auto_height: true, bg_class: icon_class) do |c| %>
                            <i class="zmdi zmdi-email"></i>
                        <% end %>
                        <%= content_tag :span, device&.enrollment_user_email || device&.windows_device_detail&.onboarding_email, title: device&.enrollment_user_email || device&.windows_device_detail&.onboarding_email %>
                    <% end %>
                </div>
                <div class="bs-col-xs-12 bs-col-sm-6 bs-col-md-6">
                    <%= sf "ListItem", title: t("windows.language") do |c| %>
                        <% c.with_icon(auto_height: true, bg_class: icon_class) do |c| %>
                            <i class="zmdi zmdi-flag"></i>
                        <% end %>
                        <%= device&.locale || I18n.t("common.na") %>
                    <% end %>
                </div>
                <div class="bs-col-xs-12 bs-col-sm-6 bs-col-md-6">
                    <%= sf "ListItem", title: t("devices.enrollment_mode") do |c| %>
                        <% c.with_icon(auto_height: true, bg_class: icon_class) do |c| %>
                            <i class="zmdi zmdi-smartphone"></i>
                        <% end %>
                        <%= I18n.t("devices.byod_mode") if device&.byod? %>
                        <%= I18n.t("devices.kiosk_mode") if device&.mode.nil? || device&.kiosk? %>
                    <% end %>
                </div>
                <div class="bs-col-xs-12 bs-col-sm-6 bs-col-md-6">
                    <%= sf "ListItem", title: t("devices.compliance_policy_group") do |c| %>
                        <% c.with_icon(auto_height: true, bg_class: icon_class) do |c| %>
                            <i class="zmdi zmdi-account"></i>
                        <% end %>
                        <%= device&.compliance_policy_group&.name || t('common.na') %>
                    <% end %>
                </div>
            <% end %>
        </dl>


        <div class="bs-d-flex bs-justify-content-end">
            <% if device.os_type == 'windows'%>
                <% unless read_only_access('Device-ReadOnly') %>
                    <% if !owner&.user_subscription&.allow_os_update_management_for_windows %>
                        <%= sf "UpgradePlan", current_user: current_user, classes: "bs-justify-content-start" do |c| %>
                            <% c.with_button do %>
                                <div class="bs-btn bs-btn-primary w-100">
                                    <%= t("devices.os_updates.view_updates") %>
                                </div>
                            <% end %>
                        <% end %>
                    <% else %>
                        <% if os_update_enabled(device) && authorized?('OSUpdateManagement') %>
                            <%= content_tag :a, class: "automation_view_updates bs-btn bs-btn-primary", data: { device_details_device_id_param: @device&.id, device_details_device_name_param: @device&.name, device_details_event_id_param: "select-windows-update", action: "device-details#redirectToOsUpdate"  } do %>
                                <%= t("devices.os_updates.view_updates") %>
                            <% end %>
                        <% else %>
                            <%= button_to view_updates_for_device_emm_windows_updates_path, method: :get, params:{page: 1, per_page: 100, device_id: device.id}, data: { turbo_frame: "view_updates_for_device_modal" }, class: "bs-btn bs-btn-primary" do %>
                                <%= t("devices.os_updates.view_updates") %>
                            <% end %>
                        <% end %>
                    <% end %>
                <% end %>
            <% end %>
            <% if device.os_type == 'android' && device&.os_update_supported? %>
                <% if !owner&.user_subscription&.allow_os_update_management_for_android %>
                    <%= sf "UpgradePlan", current_user: current_user, classes: "bs-justify-content-start" do |c| %>
                        <% c.with_button do %>
                            <div class="bs-btn bs-btn-primary w-100">
                                <%= t("devices.os_updates.view_updates") %>
                            </div>
                        <% end %>
                    <% end %>
                <% else %>
