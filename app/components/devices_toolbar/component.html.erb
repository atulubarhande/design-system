                                        </svg>
                                    <% end %>
                                <% end %>
                            </div>
                        <% end %>
                        <!-- iOS/macOS filters -->
                        <%= content_tag :div, data: { devices_filters_target: "macOsFilters" }, class: "bs-col-auto #{"bs-d-none" unless params[:filter] == "macos_devices" }" do %>
                            <%= sf "Devices::Filters::", heading: I18n.t("devices.macos") do |c| %>
                                <% c.with_custom_icon do %>
                                    <i class="zmdi zmdi-laptop-mac"></i>
                                <% end %>
                                <%= sf "BsDropdown", title: "Options", id: "ios-filters-dropdown", auto_close: true, width: "180px", classes: "bs-p-0 bs-border-0" do |c| %>
                                    <% c.with_title do %>
                                        <%= content_tag :div, I18n.t("devices.macos"), class: "bs-me-2" %>
                                    <% end %>
                                    <div class="bs-p-3">
                                        <% ["DEP Devices"].each_with_index do |filter, index| %>
                                            <%= sf "Checkbox", :data => {
                                                title: "mac-option-#{filter}",
                                                :action => "devices-filters#onIosFilterChange",
                                            }, id: "mac-option-#{index}", name:"", checked: false, label: filter %>
                                        <% end %>
                                    </div>
                                <% end %>
                            <% end %>
                        <% end %>
                        <% unless params[:deep_dive_filter].present? %>
                            <%= content_tag :div, data: { devices_filters_target: "unlicensedFilters" }, class: "bs-col-auto #{"bs-d-none" unless params[:filter] == "unlicensed" }" do %>
                                <%= form.hidden_field "", value: true, data: { name: "unlicensed", devices_filters_target: "unlicensedInput" } %>
                                <%= form.hidden_field "", value: true, data: { name: "expired", devices_filters_target: "expiredInput" } %>
                                <%= form.hidden_field "", value: true, data: { name: "unlicensed_and_expired", devices_filters_target: "unlicensedAndExpiredInput" } %>
                                <%= sf "Devices::Filters::", heading: I18n.t("v2.filters.unlicensed") do |c| %>
                                    <% c.with_custom_icon do %>
                                        <i class="zmdi zmdi-arrow-split"></i>
                                    <% end %>
                                    <%= sf "BsDropdown", title: "Options", id: "ios-filters-dropdown", auto_close: true, width: "180px", classes: "bs-p-0 bs-border-0" do |c| %>
                                        <% c.with_title do %>
                                            <%= content_tag :div, I18n.t("v2.filters.unlicensed"), class: "bs-me-2" %>
                                        <% end %>
                                        <div class="bs-p-3">
                                            <% [I18n.t("v2.filters.unlicensed_devices"), I18n.t("v2.filters.expired_licences")].each_with_index do |filter, index| %>
                                                <%= sf "Checkbox", :data => {
                                                    title: filter,
                                                    :action => "devices-filters#onUnlicensedFilterChange",
                                                }, id: "unlicensed-option-#{index}", name:"", checked: false, label: filter %>
                                                <br>
                                            <% end %>
                                        </div>
                                    <% end %>
                                <% end %>
                            <% end %>
                        <% end %>
                        <% if params[:deep_dive_filter].present? %>
                            <%= content_tag :div, class: "bs-col-auto" do %>
                                <%= button_tag(type: "button", class: "bs-btn bs-btn-outline-danger", data: { action: "devices-filters#resetDeepDiveFilters" }) do %>
                                    <%= I18n.t("common.reset") %>
                                <% end %>
                            <% end %>
                        <% end %>
                    </div>
                    <div class="bs-col-auto bs-p-0">
                        <!-- Placeholder for height flicker when filters are hidden for search -->
                        <%= content_tag :div, "Text", class: "bs-mb-2 bs-text-truncate bs-invisible" %>
                        <%= content_tag :div, class: "bs-invisible" do %>
                            <%= select_tag "count", options_for_select([]), {:class =>"bs-p-0 bs-invisible" } %>
                        <% end %>
                    </div>
                    <div class="bs-col-auto bs-d-flex bs-gap-3">
                        <% unless read_only_access('Device-ReadOnly') %>
                            <%= render "/devices/action_button_dropdown" %>
                        <% end %>
                        <!-- apply_license -->
                        <%= button_tag(type: "button", class: "bs-me-3 bs-btn bs-btn-outline-primary bs-d-none", data: { action: "devices#submitApplyLicenceForm", devices_target: "applyLicenceButton"} ) do %>
                            <%= I18n.t("v2.licenses.apply_license") %>
                        <% end %>
                    </div>
                    <!-- Elastic Input -->
                    <div class="bs-col input-container bs-d-flex bs-gap-3 bs-g-0 bs-gy-3 bs-justify-content-md-end bs-justify-content-start">
                        <% search_by_params = params[:search_by] || [] %>
                        <%= form.hidden_field "search_by", value: search_by_params, data: { devices_filters_target: "searchByParams" } %>
                        <%= form.text_field "", value: params.dig(:q), data: { action: "focus->devices-filters#onSearchFocus focus->devices#onSearchFocus devices-filters#onBasicQueryChange", devices_filters_target: "searchInput", name: "search_by[][value]" }, class: "search-input bs-form-control transition-min-width", placeholder: "Search", style: "width:100px" %>
                        <%= turbo_frame_tag "search_options", src: search_options_user_v3_devices_path(current_user, search_for: "device"), data: { devices_filters_target: "advancedSearch" }, class: "bs-w-100 bs-border bs-rounded bs-d-flex bs-align-items-center bs-d-none", loading: :lazy do %>
                            <%= form.text_field "", value: "", class: "search-input bs-form-control bs-w-100", placeholder: I18n.t("devices.advance_search_hint") %>
                        <% end %>
                        <div class="bs-d-flex bs-align-items-center bs-gap-3">
                            <%= button_tag(type: "button", class: "bs-btn bs-btn-outline-primary bs-d-none", data: { action: "devices-filters#toggleSearchType", devices_filters_target: "searchButton" }) do %>
                                <%= I18n.t("common.advanced") %>
                            <% end %>
                               
                            <%= button_tag(type: "button", class: "bs-btn bs-btn-primary bs-ms-3 bs-d-none", title: "Save Your Search", data: { action: "devices-filters#toggleSaveSearchForm", devices_filters_target: "saveSearchButton" }) do %>
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-save"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
                            <% end %>
                            <div class="bs-d-flex bs-align-items-center bs-gap-3">
                                <%= button_tag(type: "button", class: "bs-btn bs-text-primary bs-fw-semibold bs-px-2 bs-d-none", data: { action: "devices-filters#clearFilters", devices_filters_target: "clearButton" }) do %>
                                    <%= I18n.t("devices.clear_filter") %>
                                <% end %>
                                <svg data-devices-filters-target="closeButton" data-action="click->devices-filters#showBasicSearch click->devices#showBasicSearch" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-x-circle bs-text-secondary bs-btn bs-p-0 bs-d-none"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
                                <%= render "/devices/options/menu_options"%>
                            </div>
                        </div>
                    </div>
                    <!-- Elastic Input -->
                </div>
                <div class="v3-device-group-badges">
                    <div class="bs-d-flex bs-gap-1 badge-list-2 bs-align-items-center bs-mt-2">
                        <template data-devices-filters-target="searchParamBadge">
                            <li class="bs-d-flex bs-align-items-center bs-gap-1 bs-mt-1" data-action="click->devices-filters#onSearchFocus click->devices-filters#showAdvancedSearch">
                                <%= content_tag :div, "NEW_TITLE", class: "bs-bg-body-secondary bs-py-1 bs-px-2 bs-ps-3 bs-fs-6 bs-rounded-0 bs-rounded-start" %>
                                <%= content_tag :div, "NEW_OPERATOR", class: "bs-bg-body-secondary bs-py-1 bs-px-2 bs-fs-6 bs-rounded-0" %>
                                <%= content_tag :div, "NEW_VALUE", class: "bs-bg-body-secondary bs-py-1 bs-px-2 bs-pe-3 bs-fs-6 bs-rounded-0 bs-rounded-end bs-d-flex bs-align-items-center bs-me-2 bs-text-break" %>
                                <input type="hidden" value="SAVED_FILTER_ID">
                            </li>
                        </template>
                        <template data-devices-filters-target="basicSearchParamBadge">
                            <%= content_tag :div, "NEW_VALUE", class: "bs-bg-body-secondary bs-py-1 bs-px-2 bs-fs-6 bs-rounded bs-d-flex bs-align-items-center bs-me-2 bs-mt-3", data: { action: "click->devices-filters#onSearchFocus" } %>
                        </template>
                        
                        <%= content_tag :div, data: { devices_filters_target: "updatedSearchGroups" }, class: "badge-list-2 bs-d-flex bs-align-items-center bs-gap-1" do %>
                        <% end %>
                        <%= content_tag :div, data: { devices_filters_target: "remainingSearchOutput" }, class: "bs-badge bs-bg-secondary-subtle bs-text-secondary-emphasis bs-fs-6 bs-fw-normal bs-px-2 bs-py-1 bs-me-2 bs-d-flex bs-align-items-center bs-mt-1 #{"bs-d-none" unless params[:search_by].present?}" do %>
                            + 
                        <% end %>
                    </div>
                </div>
                <%# Start Rendering & Submitting forms here will again submit parent form ie devices#index %>
                <%# End %>
            <% end %>
            <%= turbo_frame_tag "confirm_filter_delete_modal_frame" %>
            <%= turbo_frame_tag "groups_filter_modal" %>
            <%= turbo_frame_tag "device_actions_modal" %>
            <%= render "/v3/devices/filters/save_search_form" %>
            <%= render "rename_devices_modal", group_id: nil, include_subgroup: nil, filter_type: nil %>
            <%= turbo_frame_tag "profiles_filter_modal" %>
            <%= turbo_frame_tag "share_filter_modal_frame" %>
            <%= turbo_frame_tag "unshare_filter_modal_frame" %>

            
            <!-- form used for move seleected Device into group -->
            <%= form_with url: move_selected_device_to_group_modal_user_v3_device_groups_path(current_user), method: :get, html: { autocomplete: "off" }, data: { devices_target: "moveSelectedDeviceToGroupForm" , turbo_frame: "move_selected_device_to_group_modal"} do |form| %>
                <%= form.hidden_field "", value: "" , data: { devices_target: "deviceType", name: 'type' }  %>
                <%= form.hidden_field "", value: "" , data: { devices_target: "userGroup", name: 'disabled_user_group'}  %>
                <%= form.hidden_field "", value: "" , data: { devices_target: "deviceGroup", name: 'disabled_device_group'}  %>
            <% end %>
            <!-- form used for Action DropDown -->
            <%= form_with url: device_actions_modal_user_v3_devices_path(current_user), method: :get, html: { autocomplete: "off" }, data: { devices_target: "deviceActionForm" , turbo_frame: "device_actions_modal"} do |form| %>
                <%= form.hidden_field "", value: "" , data: { devices_target: "deviceIdInputArray", name:'device_ids'}  %>
                <%#= form.hidden_field "", value: "" , data: { devices_target: "isNixRenameDevice", name:'is_rename_nix_device'}  %>
                <%= form.hidden_field "", value: "" , data: { devices_target: "lockedUnlock", name:'locked'}  %>
                <%= form.hidden_field "", value: "" , data: { devices_target: "actionType", name:'type'}  %>
                <%= form.hidden_field "", value: "" , data: { devices_target: "androidCount", name: 'android' }  %>
                <%= form.hidden_field "", value: "" , data: { devices_target: "nixCount", name: 'nix'}  %>
                <%= form.hidden_field "", value: "" , data: { devices_target: "iOSCount", name: 'iOS'}  %>
                <%= form.hidden_field "", value: "" , data: { devices_target: "macOsCount", name: 'macOs'}  %>
                <%= form.hidden_field "", value: "" , data: { devices_target: "chromeOsCount", name: 'chromeOs'}  %>
                <%= form.hidden_field "", value: "" , data: { devices_target: "windows", name: 'windows'}  %>
                <%= form.hidden_field "", value: "" , data: { devices_target: "printerCount", name: 'printer'}  %>
                <%= form.hidden_field "", value: "" , data: { devices_target: "tvosCount", name: 'tvos'}  %>
            <% end %>
            <%= render "devices/activated_selected_device_modal" %>

            <!-- apply licence button form -->
            <%= form_with url: apply_licence_device_list_user_v3_licences_path(current_user), method: :get, html: { autocomplete: "off" }, data: { devices_target: "applyLicenceForm" , turbo_frame: "apply_licence_device_list"} do |form| %>
            <% end %>
        <% end %>
        <div class="bs-col-4 bs-text-end">
            <button 
                data-bulk-enrollment-list-target="deleteButton"
                data-bs-toggle="modal" data-bs-target="#bulk-delete-modal"
                class="automation_delete_bulk_enrolled_devices bs-btn bs-p-0 bs-text-danger bs-me-3 bs-d-none">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-trash">
                    <polyline points="3 6 5 6 21 6"></polyline>
                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                </svg>
            </button>
        </div>
    </div>
</div>
