                                        </g>
                                    </svg>
                                <% end %>
                                <%= select_tag "count", options_for_select([100, 200, 300], (params[:count].to_i) || 100), {data: { action: "devices-filters#onCountChange" }, role: "button", :class =>"bs-form-select bs-ps-2 bs-py-1 bs-pe-5 bs-rounded-end" } %>
                            <% end %>
                        </div>
                        <template data-devices-filters-target="selectedGroupInput">
                            <li class="bs-badge bs-bg-secondary-subtle bs-text-secondary-emphasis bs-fs-6 bs-fw-normal bs-px-2 bs-py-1" title= "GROUP_NAME">
                                GROUP_NAME
                                <input type="hidden" id="NEW_ID" name="NAME_ATTR" data-type-id="TYPE_ID_ATTR" data-name-attr="NAME_ATTR" data-selected-parent-selector="GROUP_TYPE" data-hierarchical-name="HIERACHICAL_NAME" data-device-count="DEVICE_COUNT" data-parent-id="PARENT_ID" value="NEW_ID">
                            </div>
                        </template>

                        <!-- Groups -->
                        <div class="v3-device-group-badges bs-col-auto">
                            <template data-devices-filters-target="ungroupInput">
                                <li class="bs-badge bs-bg-secondary-subtle bs-text-secondary-emphasis bs-fs-6 bs-fw-normal bs-px-2 bs-py-1">
                                    <%= I18n.t("v2.groups.ungrouped") %>
                                </div>
                            </template>
                            <%= sf "Devices::Filters::", heading: I18n.t("common.groups"), show_drop_down_arrow: true do |c| %>
                                <% c.with_custom_icon do %>
                                    <svg width="17" height="16" viewBox="0 0 17 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <g id="u:users-alt" opacity="0.5" clip-path="url(#clip0_8050_4547)">
                                            <path id="Vector" d="M8.22865 8.14668C8.58436 7.83877 8.86968 7.45793 9.06523 7.03003C9.26078 6.60212 9.36198 6.13715 9.36198 5.66668C9.36198 4.78262 9.01079 3.93478 8.38567 3.30965C7.76055 2.68453 6.9127 2.33334 6.02865 2.33334C5.14459 2.33334 4.29674 2.68453 3.67162 3.30965C3.0465 3.93478 2.69531 4.78262 2.69531 5.66668C2.69531 6.13715 2.79651 6.60212 2.99206 7.03003C3.18761 7.45793 3.47293 7.83877 3.82865 8.14668C2.89541 8.56927 2.10362 9.2517 1.54797 10.1124C0.992309 10.973 0.696294 11.9755 0.695312 13C0.695312 13.1768 0.76555 13.3464 0.890575 13.4714C1.0156 13.5964 1.18517 13.6667 1.36198 13.6667C1.53879 13.6667 1.70836 13.5964 1.83338 13.4714C1.95841 13.3464 2.02865 13.1768 2.02865 13C2.02865 11.9391 2.45007 10.9217 3.20022 10.1716C3.95036 9.42144 4.96778 9.00001 6.02865 9.00001C7.08951 9.00001 8.10693 9.42144 8.85707 10.1716C9.60722 10.9217 10.0286 11.9391 10.0286 13C10.0286 13.1768 10.0989 13.3464 10.2239 13.4714C10.3489 13.5964 10.5185 13.6667 10.6953 13.6667C10.8721 13.6667 11.0417 13.5964 11.1667 13.4714C11.2917 13.3464 11.362 13.1768 11.362 13C11.361 11.9755 11.065 10.973 10.5093 10.1124C9.95367 9.2517 9.16189 8.56927 8.22865 8.14668ZM6.02865 7.66668C5.63308 7.66668 5.2464 7.54938 4.91751 7.32962C4.58861 7.10985 4.33226 6.7975 4.18089 6.43204C4.02951 6.06659 3.98991 5.66446 4.06708 5.2765C4.14425 4.88853 4.33473 4.53217 4.61443 4.25246C4.89414 3.97276 5.2505 3.78228 5.63847 3.70511C6.02643 3.62794 6.42856 3.66754 6.79401 3.81892C7.15947 3.97029 7.47182 4.22664 7.69159 4.55554C7.91135 4.88443 8.02865 5.27111 8.02865 5.66668C8.02865 6.19711 7.81793 6.70582 7.44286 7.08089C7.06779 7.45596 6.55908 7.66668 6.02865 7.66668ZM12.522 7.88001C12.9486 7.39956 13.2273 6.80605 13.3245 6.1709C13.4217 5.53576 13.3333 4.88606 13.0698 4.30001C12.8064 3.71396 12.3792 3.21654 11.8396 2.86763C11.3001 2.51871 10.6712 2.33317 10.0286 2.33334C9.85184 2.33334 9.68227 2.40358 9.55724 2.52861C9.43222 2.65363 9.36198 2.8232 9.36198 3.00001C9.36198 3.17682 9.43222 3.34639 9.55724 3.47141C9.68227 3.59644 9.85184 3.66668 10.0286 3.66668C10.5591 3.66668 11.0678 3.87739 11.4429 4.25246C11.8179 4.62754 12.0286 5.13624 12.0286 5.66668C12.0277 6.01684 11.9348 6.36061 11.7594 6.66362C11.5839 6.96664 11.3319 7.21826 11.0286 7.39334C10.9298 7.45036 10.8473 7.53179 10.7889 7.62984C10.7305 7.72789 10.6983 7.83928 10.6953 7.95334C10.6925 8.06652 10.7186 8.17854 10.7711 8.27885C10.8236 8.37916 10.9007 8.46445 10.9953 8.52668L11.2553 8.70001L11.342 8.74668C12.1456 9.12782 12.8235 9.73067 13.296 10.4842C13.7684 11.2378 14.0157 12.1106 14.0086 13C14.0086 13.1768 14.0789 13.3464 14.2039 13.4714C14.3289 13.5964 14.4985 13.6667 14.6753 13.6667C14.8521 13.6667 15.0217 13.5964 15.1467 13.4714C15.2717 13.3464 15.342 13.1768 15.342 13C15.3474 11.977 15.0912 10.9695 14.5976 10.0734C14.1041 9.17726 13.3895 8.42222 12.522 7.88001Z" fill="black"/>
                                        </g>
                                        <defs>
                                            <clipPath id="clip0_8050_4547">
                                                <rect width="16" height="16" fill="white" transform="translate(0.03125)"/>
                                            </clipPath>
                                        </defs>
                                    </svg>
                                <% end %>
                                <% if params[:deep_dive_filter].present? %>
                                    <%= content_tag :div, deep_dive_filter(params[:deep_dive_filter], "group_name") || I18n.t("common.none"), class: "bs-badge bs-bg-secondary-subtle bs-text-secondary-emphasis bs-fs-6 bs-fw-normal bs-px-2 bs-py-1 bs-me-2" %>
                                <% else %>
                                    <%= link_to groups_filter_modal_user_v3_devices_path(current_user), method: :get, target: "groups_filter_modal", data: { turbo_frame: "groups_filter_modal", devices_filters_target: "fetchGroupsAnchor" }, class: "bs-ps-1 bs-py-1 bs-d-flex bs-align-items-center selected-group-badges" do %> 
                                        <!--
                                            <%= sf "SelectedDeviceGroupsDynamicBadges::", template_target: "devices-filters" ,  selected_groups: { devices_filters_target: "updatedGroups"}, remaining_count: { devices_filters_target: "remainingOutput" } , none_selected: { devices_filters_target:"noneSelected" }, badge_count: 2, badge_data: { devices_filters_target: "selectedGroup" }, text: t("common.none") do |c| %>
                                                <% c.with_hidden_input do %>
                                                    <input type="hidden" id="NEW_ID" name="NAME_ATTR" data-type-id="TYPE_ID_ATTR" data-name-attr="NAME_ATTR" data-selected-parent-selector="GROUP_TYPE" data-hierarchical-name="HIERACHICAL_NAME" data-device-count="DEVICE_COUNT" data-parent-id="PARENT_ID" value="NEW_ID">
                                                <% end %>
                                            <% end %>
                                        -->
                                         <%= content_tag :div, data: { devices_filters_target: "updatedGroups" }, class: "badge-list-2 bs-d-flex bs-align-items-center bs-gap-1" do %>
                                            <% end %>
                                        <%= content_tag :div, data: { devices_filters_target: "remainingOutput" }, class: "bs-badge bs-bg-secondary-subtle bs-text-secondary-emphasis bs-fs-6 bs-fw-normal bs-px-2 bs-py-1 bs-ms-1 bs-me-2 #{"bs-d-none" unless params.dig(:group).present? }" do %>
                                            + 
                                        <% end %>
                                        <%= content_tag :div, data: { devices_filters_target:"noneSelected" }, class: "bs-badge bs-bg-secondary-subtle bs-text-secondary-emphasis bs-fs-6 bs-fw-normal bs-px-2 bs-py-1 bs-me-2 #{"bs-d-none" if params.dig(:group).present? }" do %>
                                            <%= I18n.t("common.none") %>
                                        <% end %>
                                    <% end %>
                                <% end %>
                            <% end %>
                        </div>

                        <template data-devices-filters-target="selectedProfileInput">
                            <li class="bs-badge bs-bg-secondary-subtle bs-text-secondary-emphasis bs-fs-6 bs-fw-normal bs-px-2 bs-py-1" title= "PROFILE_NAME">
                                PROFILE_NAME
                                <input type="hidden" id="PROFILE_ID" name="profiles[]" data-name-attr="PROFILE_NAME_ATTR" value="PROFILE_ID">
                            </div>
                        </template>

                        <!-- Profiles -->
                        <div class="v3-device-group-badges bs-col-auto">
                            <template data-devices-filters-target="noProfileInput">
                                <li class="bs-badge bs-bg-secondary-subtle bs-text-secondary-emphasis bs-fs-6 bs-fw-normal bs-px-2 bs-py-1">
                                    <%= I18n.t("v2.profiles.no_profile") %>
                                </div>
                            </template>
                            <%= sf "Devices::Filters::", heading: I18n.t("common.profiles"), show_drop_down_arrow: true do |c| %>
