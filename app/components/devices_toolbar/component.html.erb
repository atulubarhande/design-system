<div class="bs-card bs-border-0 bs-shadow-sm bs-p-4 bs-mb-3 bs-row bs-g-0">
    <div class="bs-row bs-align-items-center">
        <%= content_tag :div, class: "bs-col-12 device-filters-wrapper", data: {
            controller: "devices-filters",
            action: "turbo:submit-end->devices-filters#submitEnd turbo:submit-start->devices-filters#submitStart",
            devices_filters_hidden_class: "bs-d-none",
            devices_filters_transition_class: "transition-d-none",
            devices_filters_full_width_class: "bs-w-100",
            devices_filters_advanced_text_value: I18n.t("common.advanced"),
            devices_filters_has_deep_dive_value: params[:deep_dive_filter].present?,
            devices_filters_android_filter_value: "android_devices",
            devices_filters_user_id_value: current_user.id,
            devices_filters_basic_text_value: I18n.t("common.basic"),
            devices_filters_basic_search_hint_value: I18n.t("devices.basic_search_hint"),
            devices_filters_groups_url_value: request&.base_url + groups_filter_modal_user_v3_devices_path(current_user),
            devices_filters_input_expanded_class: "bs-w-100" ,
            devices_filters_bulk_entity_threshold_value: current_user.bulk_entity_threshold_reached?('groups'),
            devices_filters_profiles_url_value: request&.base_url + profiles_filter_modal_user_v3_devices_path(current_user),
            devices_filters_accessible_device_filter_ids_value: current_user.accessible_device_filters.pluck(:id)} do %>
            <!-- Used to reset filter bar -->
            <%= form_with(url: user_devices_path(current_user), method: :get, data: {
                    turbo_stream: "",
                    devices_filters_target: "resetAnchor"
                }, class: "bs-d-none") do |form| %>
                    <%= form.hidden_field "compact", value: true %>
                    <%= form.hidden_field "count", value: 100 %>
                    <%= form.hidden_field "page", value: 1 %>
                    <%= form.hidden_field "only_android", value: false %>
                    <%= form.hidden_field "only_byod", value: false %>
                    <%= form.hidden_field "orphans", value: false %>
                    <%= form.hidden_field "orphans_ios", value: false %>
                    <%= form.hidden_field "orphans_mac", value: false %>
                    <%= form.hidden_field "orphans_nix", value: false %>
                    <%= form.hidden_field "only_apple_user_enrolled_ios", value: false %>
                    <%= form.hidden_field "only_company_owned_enrolled_ios", value: false %>
                    <%= form.hidden_field "orphans_windows", value: false %>
                    <%= form.hidden_field "skip_amapi", value: false %>
                    <%= form.hidden_field "skip_byod", value: false %>
                    <%= form.hidden_field "skip_macos", value: false %>
                    <%= form.hidden_field "ungrouped", value: false %>
                    <%= form.hidden_field "unscoped", value: true %>
                    <%= form.hidden_field "reset", value: true %>
                    <%= form.hidden_field "order_by", value: "name" %>
                    <%= form.hidden_field "sorting", value: "asc" %>
                    <%= form.hidden_field "with_no_profile", value: false %>
                    <% if params[:deep_dive_filter].present? %>
                        <%= form.hidden_field "deep_dive_filter", value: params[:deep_dive_filter] %>
                    <% end %>
            <% end %>
            <!-- devices_target: "form" is shared by device controller for sorting and form submission -->
            <%= form_with(url: user_devices_path(current_user) , method: :get, data: {
                    devices_target: "form",
                    devices_filters_target: "form",
                    turbo_stream: ""
                }) do |form| %>
                <%= form.hidden_field "compact", value: true %>
                <%= form.hidden_field "page", value: params[:page] || 1, data: { devices_target: "page", devices_filters_target: "page" } %>
                <%= form.hidden_field "only_android", value: params[:filter] == "android_devices" ? true  : false, data: { devices_filters_target: "onlyAndroidInput" } %>
                <%= form.hidden_field "only_byod", value: false %>
                <!-- prevent using default sorting ie "name" -->
                <%= form.hidden_field "order_by", value: params[:order_by].present? ? params[:order_by] : "name", data: { devices_target: "orderBy" } %>
                <%= form.hidden_field "sorting", value: params[:sorting] || "desc", data: { devices_target: "sorting" } %>
                <%= form.hidden_field "orphans", value: false %>
                <%= form.hidden_field "orphans_ios", value: false %>
                <%= form.hidden_field "orphans_mac", value: false %>
                <%= form.hidden_field "orphans_nix", value: false %>
                <%= form.hidden_field "skip_amapi", value: false %>
                <%= form.hidden_field "skip_byod", value: false %>
                <%= form.hidden_field "skip_macos", value: false %>
                <%= form.hidden_field "ungrouped", value: params[:ungrouped], data:{ devices_filters_target: "ungroupedHiddenInput" } %>
                <%= form.hidden_field "unscoped", value: true %>
                <%= form.hidden_field "only_apple_user_enrolled_ios", value: false %>
                <%= form.hidden_field "only_company_owned_enrolled_ios", value: false %>
                <%= form.hidden_field "orphans_windows", value: false %>
                <%= form.hidden_field "with_no_profile", value: params[:with_no_profile], data:{ devices_filters_target: "noProfileHiddenInput" } %>
                <% if params[:emm_enabled].present? %> 
                    <%= form.hidden_field "emm_enabled", value: params[:emm_enabled] %>
                <% end %>
                <% if params[:certificate_id].present? %>
                    <%= form.hidden_field "certificate_id", value: params[:certificate_id] %>
                <% end %>
                <% if request.format.turbo_stream? && params[:group].present? %>
                    <% params[:group].each do |group| %>
                        <%= form.hidden_field "group[]", value: group %>
                    <% end %>
                <% end %>
                <% if request.format.turbo_stream? && params[:organization_unit].present? %>
                  <% params[:organization_unit].each do |group| %>
                    <%= form.hidden_field "organization_unit[]", value: group %>
                  <% end %>
                <% end %>
                <% if request.format.turbo_stream? && params[:profiles].present? %>
                    <% params[:profiles].each do |profile| %>
                        <%= form.hidden_field "profiles[]", value: profile %>
                    <% end %>
                <% end %>
                <% if params[:profiles_data].present? && JSON.parse(params[:profiles_data]).present? %>
                    <%= form.hidden_field "profiles_data", value: params[:profiles_data] %>
                <% end %>
                <% if params[:deep_dive_filter].present? %>
                    <%= form.hidden_field "deep_dive_filter", value: params[:deep_dive_filter] %>
                <% end %>
                <div class="filter-toolbar-container bs-row bs-g-3 bs-align-items-end">
                    <div class="bs-col-auto bs-row bs-align-items-end bs-gap-3 bs-g-0" data-devices-filters-target="filterItem">
                        <!-- View filter -->
                        <div class="bs-col-auto">
                            <%= content_tag :div, I18n.t("common.view"), class: "bs-mb-2 filter-title bs-text-body-secondary" %>
                            <%= content_tag :div, class: "bs-input-group" do %>
                                <%= label_tag "filter", class: "bs-input-group-text bs-m-0 bs-border-end-0" do %>
                                    <svg width="17" height="16" viewBox="0 0 17 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <g id="u:eye" opacity="0.5">
                                            <path id="Vector" d="M14.6417 7.73332C13.295 4.60666 10.7617 2.66666 8.02837 2.66666C5.29503 2.66666 2.7617 4.60666 1.41503 7.73332C1.37832 7.81743 1.35938 7.90822 1.35938 7.99999C1.35938 8.09176 1.37832 8.18255 1.41503 8.26666C2.7617 11.3933 5.29503 13.3333 8.02837 13.3333C10.7617 13.3333 13.295 11.3933 14.6417 8.26666C14.6784 8.18255 14.6974 8.09176 14.6974 7.99999C14.6974 7.90822 14.6784 7.81743 14.6417 7.73332ZM8.02837 12C5.91503 12 3.91503 10.4733 2.7617 7.99999C3.91503 5.52666 5.91503 3.99999 8.02837 3.99999C10.1417 3.99999 12.1417 5.52666 13.295 7.99999C12.1417 10.4733 10.1417 12 8.02837 12ZM8.02837 5.33332C7.50095 5.33332 6.98538 5.48972 6.54684 5.78274C6.10831 6.07575 5.76652 6.49223 5.56469 6.9795C5.36285 7.46677 5.31004 8.00295 5.41294 8.52023C5.51583 9.03751 5.76981 9.51267 6.14275 9.88561C6.51569 10.2585 6.99084 10.5125 7.50812 10.6154C8.02541 10.7183 8.56158 10.6655 9.04885 10.4637C9.53612 10.2618 9.9526 9.92004 10.2456 9.48151C10.5386 9.04298 10.695 8.52741 10.695 7.99999C10.695 7.29275 10.4141 6.61447 9.91398 6.11437C9.41389 5.61427 8.73561 5.33332 8.02837 5.33332ZM8.02837 9.33332C7.76466 9.33332 7.50687 9.25512 7.2876 9.10862C7.06834 8.96211 6.89744 8.75387 6.79653 8.51023C6.69561 8.2666 6.6692 7.99851 6.72065 7.73987C6.7721 7.48123 6.89909 7.24365 7.08556 7.05718C7.27203 6.87071 7.5096 6.74372 7.76824 6.69228C8.02689 6.64083 8.29497 6.66723 8.53861 6.76815C8.78224 6.86907 8.99048 7.03996 9.13699 7.25923C9.2835 7.4785 9.3617 7.73628 9.3617 7.99999C9.3617 8.35361 9.22122 8.69275 8.97117 8.9428C8.72113 9.19285 8.38199 9.33332 8.02837 9.33332Z" fill="black"/>
                                        </g>
                                    </svg>
                                <% end %>
                                <% if params[:deep_dive_filter].present? %>
                                    <%= content_tag :div, class: "bs-border bs-py-1 bs-rounded-end bs-ps-2 bs-py-1" do %>
                                        <%= content_tag :div, replace_string(params[:deep_dive_filter], "tab"), class: "bs-me-2" %>
                                    <% end %>
                                <% else %>
                                    <%= select_tag "filter", options_for_select(view_filter_options, params[:filter]), {data: { devices_filters_target: "filter", action: "devices-filters#onFilterChange" }, role: "button", :class =>"bs-form-select bs-ps-2 bs-py-1" } %>
                                <% end %>
                            <% end %>
                        </div>
                        <!-- Per Page -->
                        <div class="bs-col-auto <%= "bs-d-none" if params[:deep_dive_filter].present? %>">
                            <%= content_tag :div, I18n.t("common.per_page"), class: "bs-mb-2 filter-title bs-text-body-secondary" %>
                            <%= content_tag :div, class: "bs-input-group" do %>
                                <%= label_tag "count", class: "bs-input-group-text bs-m-0 bs-border-end-0" do %>
                                    <svg width="17" height="16" viewBox="0 0 17 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <g id="u:document-info" opacity="0.5">
                                            <path id="Vector" d="M8.02865 9.33334C7.85183 9.33334 7.68227 9.40358 7.55724 9.52861C7.43222 9.65363 7.36198 9.8232 7.36198 10V11.3333C7.36198 11.5102 7.43222 11.6797 7.55724 11.8047C7.68227 11.9298 7.85183 12 8.02865 12C8.20546 12 8.37503 11.9298 8.50005 11.8047C8.62507 11.6797 8.69531 11.5102 8.69531 11.3333V10C8.69531 9.8232 8.62507 9.65363 8.50005 9.52861C8.37503 9.40358 8.20546 9.33334 8.02865 9.33334ZM8.28198 7.38668C8.1613 7.33072 8.02664 7.31215 7.89531 7.33334L7.77531 7.37334L7.65531 7.43334L7.55531 7.51334C7.49191 7.57721 7.44209 7.65326 7.40886 7.7369C7.37563 7.82054 7.35969 7.91004 7.36198 8.00001C7.36147 8.08775 7.37829 8.17472 7.41147 8.25595C7.44464 8.33717 7.49352 8.41105 7.55531 8.47334C7.61871 8.53404 7.69348 8.58161 7.77531 8.61334C7.85443 8.65066 7.94119 8.66893 8.02865 8.66668C8.11638 8.66718 8.20336 8.65037 8.28458 8.61719C8.36581 8.58401 8.43969 8.53513 8.50198 8.47334C8.56377 8.41105 8.61265 8.33717 8.64583 8.25595C8.679 8.17472 8.69582 8.08775 8.69531 8.00001C8.69582 7.91227 8.679 7.8253 8.64583 7.74407C8.61265 7.66285 8.56377 7.58897 8.50198 7.52668C8.43718 7.46779 8.36277 7.42044 8.28198 7.38668ZM13.362 5.96001C13.355 5.89877 13.3416 5.83843 13.322 5.78001V5.72001C13.2899 5.65146 13.2472 5.58845 13.1953 5.53334L9.19531 1.53334C9.1402 1.48149 9.07719 1.43873 9.00865 1.40668H8.94198C8.87715 1.37201 8.80749 1.34729 8.73531 1.33334H4.69531C4.16488 1.33334 3.65617 1.54406 3.2811 1.91913C2.90603 2.2942 2.69531 2.80291 2.69531 3.33334V12.6667C2.69531 13.1971 2.90603 13.7058 3.2811 14.0809C3.65617 14.456 4.16488 14.6667 4.69531 14.6667H11.362C11.8924 14.6667 12.4011 14.456 12.7762 14.0809C13.1513 13.7058 13.362 13.1971 13.362 12.6667V6.00001C13.362 6.00001 13.362 6.00001 13.362 5.96001ZM9.36198 3.60668L11.0886 5.33334H10.0286C9.85183 5.33334 9.68227 5.26311 9.55724 5.13808C9.43222 5.01306 9.36198 4.84349 9.36198 4.66668V3.60668ZM12.0286 12.6667C12.0286 12.8435 11.9584 13.0131 11.8334 13.1381C11.7084 13.