                                        <% end %>
                                    </div>
                                <% end %>
                            <% end %>
                        <% end %>
                        <% if params[:deep_dive_filter].present? %>
                            <!-- deep dive filters -->
                            <div class="bs-col-auto">
                                <%= content_tag :div, replace_string(params[:deep_dive_filter], "type"), class: "bs-mb-2 filter-title bs-text-body-secondary" %>
                                <%= content_tag :div, class: "bs-input-group" do %>
                                    <%= label_tag "", class: "bs-input-group-text bs-m-0 bs-rounded-end bs-text-secondary bs-fs-5" do %>
                                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="bs-text-secondary" xmlns="http://www.w3.org/2000/svg">
