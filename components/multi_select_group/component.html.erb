                organization_unit_counts: @organization_unit_counts,
                parent_group: @checkbox_group,
                name: @name,
                include_user_groups_ids: @include_user_groups_ids,
                include_device_groups_ids: @include_device_groups_ids,
                include_organization_units_ids: @include_organization_units_ids,
