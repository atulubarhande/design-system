<% @id = @type =="checkbox" ? "#{dom_id(@checkbox_group)}" : "#{@group }_"+ "#{@type}_" + dom_id(@checkbox_group) %> 
<% if @is_unpublish_group.to_s == "true" %>
    <% if (@checkbox_group.sub_groups.present?) %>
        <div class="bs-d-flex bs-align-items-center" data-name="<%= group_n_sub_group_names(@checkbox_group) %>" data-search-target="item">
