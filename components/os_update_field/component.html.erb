<% case @field_type %>
<% when "select" %>
    <%= sf "FormGroupRow::", col_classes: [6, 6] do |c| %>
        <% c.with_custom_label do %>
            <%= sf "Label::", label: @label,
                description: @description %>
        <% end %>
        <% c.with_input do %>
            <%= sf "Select::",
                name: @name,
                data: @data,
                label: nil,
                list: @options,
                disabled: @disabled,
                has_null_option: @has_null_option,
                promt_message: @promt_message,
                selected: @value %>
        <% end %>
    <% end %>
<% when "text" %>
    <%= sf "FormGroupRow::", col_classes: [6, 6] do |c| %>
        <% c.with_custom_label do %>
            <%= sf "Label::", label: @label, description: @description %>
        <% end %>
        <% c.with_input do %>
            <%= sf "TextField::",
                placeholder: @placeholder,
                name: @name,
                disabled: @disabled,
                data: @data,
                value: @value %>
        <% end %>
    <% end %>
<% when "input_number" %>
    <%= sf "FormGroupRow::", col_classes: [6, 6] do |c| %>
        <% c.with_custom_label do %>
            <%= sf "Label::", label: @label, description: @description %>
        <% end %>
        <% c.with_input do %>
            <%= sf "TextField::",
                type: "number",
                min: @min,
                data: @data,
                max: @max,
                disabled: @disabled,
                placeholder: @placeholder,
                name: @name,
                value: @value %>
        <% end %>
    <% end %>
<% when "zero_one_switch" %>
    <%= sf "FormGroupRow::", col_classes: [6, 6] do |c| %>
        <% c.with_custom_label do %>
            <%= sf "Label::", id: @checkbox_id, label: @label,
                description: @description %>
        <% end %>
        <% c.with_input do %>
            <%= sf "ZeroOneSwitch::", id: @checkbox_id, value: @value, name: @name, data: @data, disabled: @disabled %>
        <% end %>
    <% end %>
<% when "switch" %>
    <%= sf "FormGroupRow::", col_classes: [6, 6] do |c| %>
        <% c.with_custom_label do %>
            <%= sf "Label::", id: @checkbox_id, label: @label,
                description: @description %>
        <% end %>
        <% c.with_input do %>
            <%= sf "Switch::", id: @checkbox_id, checked: @value, name: @name, data: @data, disabled: @disabled %>
        <% end %>
    <% end %>

<% when "textarea" %>
    <%= sf "FormGroupRow::", col_classes: [6, 6] do |c| %>
        <% c.with_custom_label do %>
            <%= sf "Label::", label: @label,
                description: @description %>
        <% end %>
        <% c.with_input do %>
            <%= sf "TextArea::",
                name: @name,
                value: @value, 
                rows: @rows, 
                cols: @cols, 
                placeholder: @placeholder,
                data: @data %>
        <% end %>
    <% end %>
<% end %>
