<div class="bs-d-inline-flex tw-rounded-md tw-shadow-sm" data-controller="<%= show_dropdown ? "dropdown" : "" %>" data-action="click@document->dropdown#handleClickOutside">
    <% if title? %>
        <%= title %>
    <% end %>
    <% if show_dropdown %>
    <div class="bs-position-relative tw--ml-px bs-d-block">
        <button type="button" data-action="click->dropdown#toggleMenu" data-dropdown-target="button" class="tw-button-group-dropdown " id="option-menu-button" aria-expanded="true" aria-haspopup="true">
            <span class="tw-sr-only">Open options</span>
            <svg class="tw-h-5 tw-w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
            </svg>
        </button>
        <div class="tw-dropdown-menu tw-ring-opacity-5 <%= @width %> hidden"
        data-dropdown-target="menu"
        id="dropdown-dropdown-menu-items"
        data-transition-enter="tw-transition tw-ease-out tw-duration-100"
        data-transition-enter-start="tw-transform tw-opacity-0 tw-scale-95"
        data-transition-enter-end="tw-transform tw-opacity-100 tw-scale-100"
        data-transition-leave="tw-transition tw-ease-in tw-duration-75"
        data-transition-leave-start="tw-transform tw-opacity-100 tw-scale-100"
        data-transition-leave-end="tw-transform tw-opacity-0 tw-scale-95" role="menu" aria-orientation="vertical" aria-labelledby="option-menu-button" tabindex="-1">
            <div class="tw-py-2 tw-bg-white tw-rounded-md " role="none">
            <div data-action="click->dropdown#toggleMenu"><%= content %></div>
            </div>
        </div>
    </div>
    <% end %>
</div>
