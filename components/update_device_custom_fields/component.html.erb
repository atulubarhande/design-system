<div>
    <% if @note %>
        <div class="bs-alert bs-alert-warning bs-d-flex bs-align-items-center" role="alert">
            <%= @note %>
        </div>
    <% end %>
    <div class="bs-d-flex bs-justify-content-end bs-pb-3">
        <%= form_with url: "#{csv_user_v3_devices_path(@current_user)}.json?csv_type=#{@csv_type}", method: :get, data: { controller: 'eva-settings', eva_settings_request_faild_value: t('common.request_failed') } do |form| %>
            <div>
            <%= form.hidden_field "csv_type", value: "custom_fields" %>
                <%= button_tag(type: 'button', class: "bs-ms-3 bs-btn bs-btn-primary bs-d-flex bs-align-items-center", data: {action: "eva-settings#downloadCsv", eva_settings_target: "downloadButton"}) do %>
                    <i class="bs-me-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-download" viewBox="0 0 16 16">
                            <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"/>
                            <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708l3 3z"/>
                        </svg>
                    </i>
                    <%= I18n.t("common.download_csv") %>
                <% end %>
            </div>
        <% end %>
    </div>
</div>
