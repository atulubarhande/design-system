<%= content_tag :div, data: { controller: "select-with-reset", select_with_reset_hidden_class: "bs-d-none" }, class: "bs-d-flex bs-align-items-end" do %>
    <%= sf "Select::",
        id: @id,
        name: @name,
        label: @label,
        promt_message: @promt_message,
        container_classes: @container_classes,
        has_null_option: @has_null_option,
        list: @list,
        disabled: @disabled,
        selected: @selected,
        data: @data.merge({ select_with_reset_target: "select", action: "select-with-reset#onSelect #{@action}" }) %>
    <button type="button" class="bs-btn bs-d-flex bs-align-items-center <%= "bs-d-none" unless @selected %>" data-action="<%= @remove_action %> select-with-reset#resetAllSelect" data-select-with-reset-target="removeButton">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-x"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
<% end %>