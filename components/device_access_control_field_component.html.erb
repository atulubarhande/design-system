<div class="bs-my-3">
    <div class="bs-d-flex bs-align-items-end">
        <%= hidden_field_tag @hidden_field_name, @key_name %>
        <%= label_tag @name, class: "bs-form-label bs-fs-6 bs-text-body-secondary bs-col-8" do %>
            <%= @label %>
            <% if @platform_logo %>
                <%= sf "PlatformSupport", platform: @platform_logo %>
            <% end %>
        <% end %>

        <% if @field_type == 'Select' %>
            <%= select_tag @name, options_for_select(@list, @value), 
                { class: "bs-form-select bs-col",
                  id: @name,
                  data: @data
                }
            %>
        <% elsif @field_type == 'Checkbox' %>
            <div class="bs-form-check bs-form-switch bs-d-flex bs-align-items-center bs-flex-row-reverse bs-ps-0 bs-justify-content-between">
                <div class="bs-d-flex bs-justify-content-sm-end">
                    <div class="bs-d-flex bs-justify-content-sm-end">
                        <input class="bs-form-check-input bs-ms-2 bs-mt-0"
                               type="checkbox"
                               name="<%= @name %>"
                               <% if @value == 'true' %> checked  <% end %>
                               value="true"
                               <% if @data != nil %> <%= @data %> <% end %>
                        >
                    </div>
                </div>
            </div>
        <% end %>
    </div>
</div>