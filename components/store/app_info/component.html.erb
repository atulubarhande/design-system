
<div class="bs-accordion-item">
    <% unless @app.wingman_app %>
        <h2 class="bs-accordion-header">
            <button class="bs-accordion-button bs-bg-primary-subtle <%= "bs-collapsed" unless @is_open %>" type="button" data-bs-toggle="collapse" data-bs-target="#flush-collapseOne-<%= @latest_release.id %>" aria-expanded="false" aria-controls="flush-collapseOne-<%= @latest_release.id %>">
                <% if @app&.latest_release.present? && @app.latest_release.version_code == @app_version&.to_i %>
                    <%= content_tag :div, "#{t("common.app_version")} #{@app_version} (#{@app.latest_release.version_code if @app.latest_release})", class: "bs-fw-normal" %>
                <% else %>
                    <%= content_tag :div, "#{t("common.app_version")} #{@app_version}", class: "bs-fw-normal" %>
                <% end %>
            </button>
        </h2>
    <% end %>
    <div id="flush-collapseOne-<%= @latest_release.id %>" class="bs-accordion-collapse bs-collapse <%= "bs-show" if @is_open %>" data-bs-parent="#accordionFlushExample">
        <div class="accordion-body">
            <div class="bs-d-flex bs-flex-column bs-gap-4 bs-border-0 bs-p-4">
                <% unless read_only_access('AppStore-ReadOnly') %>
                    <% unless @app.wingman_app %>
                        <div class="bs-d-flex bs-justify-content-between bs-align-items-center">
                            <div class="bs-d-flex bs-gap-3 bs-align-items-center">

                                <% if current_user.admin_parent.amapi_activated? %>
                                    <%= button_tag({ data: { bs_toggle: "modal", bs_target: "#upload-enterprise-app-amapu-setup-modal" }, class: "bs-btn bs-btn-primary automation_store_app_publish_button" }) do %>
                                        <%= t("common.publish") %>
                                    <% end %>
                                <% else %>
                                    <%= button_to store_publishable_data_path(@app),
                                        method: :get,
                                        params: {
                                            release_id: @latest_release.id,
                                            app_type: params[:app_type],
                                            app_pf: params[:app_pf],
                                            platform: params[:app_pf].downcase,
                                            name: "device_group_ids[]",
                                            org_user_group_name: "user_group_ids[]"
                                        }, data: {
                                            turbo_frame: "store_publishable_data"
                                        }, class: "bs-btn bs-btn-primary automation_store_app_publish_button" do %>
                                        <%= t("common.publish") %>
                                    <% end %>
                                <% end %>
                                <% if app_type == 'myApps' || uninstallable_app? %>
                                    <%= button_to uninstall_data_store_path(@app),
                                        method: :get,
                                        params: {
                                            release_id: @latest_release.id,
                                            app_type: params[:app_type],
                                            app_pf: params[:app_pf],
                                            platform: params[:app_pf].downcase,
                                            name: "device_group_ids[]",
                                            org_user_group_name: "user_group_ids[]"
                                        }, data: {
                                            turbo_frame: "store_uninstall_data"
                                        }, class: "bs-btn bs-btn-outline-primary automation_store_app_uninstall_button" do %>
                                            <%= t("enterpriseStore.uninstall") %>
                                    <% end %>
                                <% end %>
                                <% if @latest_release.mapping_present?(current_user) && app_type == 'myApps' %>
                                    <%= button_to uninstall_data_store_path(@app),
                                        method: :get,
                                        params: {
                                            release_id: @latest_release.id,
                                            app_type: params[:app_type],
                                            action_type: "stop_rollout",
                                            platform: params[:app_pf].downcase,
                                            name: "device_group_ids[]",
                                            org_user_group_name: "user_group_ids[]"
                                        }, data: {
                                            turbo_frame: "store_uninstall_data"
                                        }, class: "bs-btn bs-btn-outline-danger automation_store_app_stop_rollout_button" do %>
                                        <%= t("enterpriseStore.stop_rollout") %>
                                    <% end %>
                                <% end %>

                            </div>
                            <div class="bs-d-flex bs-gap-4 bs-align-items-center">
                                <%= button_to store_download_apk_url_path(@app), method: :get, params: { release_id: @latest_release.id, has_download: false }, data: { turbo_stream: ""}, :class => "bs-btn bs-p-0",  title: t('enterpriseStore.copy_download_link')  do %>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="rgb(108, 117, 125)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-clipboard"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect></svg>
                                <% end %>
                                <%= button_to store_download_apk_url_path(@app), method: :get, params: { release_id: @latest_release.id, has_download: true }, data: { turbo_stream: ""}, :class => "bs-btn bs-p-0",  title: t('enterpriseStore.download_app')  do %>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="rgb(108, 117, 125)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-download"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                                <% end %>
                            </div>
                        </div>
                    <% end %>
                <% end %>
                <div class="bs-row bs-g-3">
                    <% if @latest_release.present? %>
                        <%= content_tag :div, I18n.t("common.size"), class: "bs-col-4 bs-text-secondary" %>
                        <%= content_tag :div, number_to_human_size(@latest_release.apk_size), class: "bs-col-8" %>
                        <%= content_tag :div, I18n.t("enterpriseStore.uploaded_on"), class: "bs-col-4 bs-text-secondary" %>
                        <%= content_tag :div, @latest_release.created_at.strftime('%b %d, %Y'), class: "bs-col-8" %>
                    <% end %>
                    <%= content_tag :div, t("common.installed_on"), class: "bs-col-4 bs-text-secondary" %>
                    <%= content_tag :div, class: "bs-col-8" do %>
                        <%= content_tag :div, class: "bs-row" do %>
                            <%= content_tag :div, class: "bs-col-6" do %>
                                <%= @installed_on %>
                            <% end %>
                            <% unless read_only_access('AppStore-ReadOnly') %>
                                <% if @installed_on > 0 && @app.reinstallable_app?  %>
                                    <%= content_tag :div, class: "bs-col-6" do %>
                                        <%= button_to store_reinstallation_path(@app), params: {
                                          release_id: @latest_release.id,
                                          app_type: params[:app_type],
                                          app_pf: params[:app_pf]}, method: :get, data: { turbo_frame: "store_publishable_data" }, class: "bs-btn bs-px-0 bs-fw-bold bs-text-primary automation_store_app_view_status_button" do %>
                                            <%= t("common.reinstall") %>
                                        <% end %>
                                    <% end %>
                                <% end %>
                            <% end %>
                        <% end %>
                    <% end %>

                    <%= content_tag :div, t("common.published_to"), class: "bs-col-4 bs-text-secondary" %>
                    <%= content_tag :div, @published_to, class: "bs-col-8" %>
                </div>
                <% unless read_only_access('AppStore-ReadOnly') %>
                    <% if !@app.wingman_app %>
                        <% if @app.allow_previous_release?(current_user) && ( @previous_releases_count&.present? ? @previous_releases_count >= 1 : false ) %>
                            <%= sf "BsDropdown", title: "store-apps-delete-options", id: "device-dropdown", width: "150px", classes: "bs-p-0" do |c| %>
                                <% c.with_title do %>
                                    <%=content_tag :div, I18n.t("common.delete_version"), class: "bs-btn bs-px-2 bs-text-danger automation_store_app_delete_dropdown_button bs-pe-5 bs-form-select" %>
                                <% end %>
                                <%= content_tag :div, data: { bs_dismiss: "bs-offcanvas" } do %>
                                    <%= button_tag({ data: { bs_toggle: "modal", bs_target: "#enterprises-app-release-first-delete-modal-#{@latest_release.id}" }, :class => "automation_store_app_delete_button bs-dropdown-item bs-py-2 bs-d-flex bs-gap-3 bs-align-items-center"}) do %>                                                                          
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-trash"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>                                <%= t("common.delete") %>
                                    <% end %>
                                    <%= button_tag({ data: { bs_toggle: "modal", bs_target: "#enterprises-app-release-first-delete-and-uninstall-modal-#{@latest_release.id}" }, :class => "automation_store_app_delete_and_uninstall_button bs-dropdown-item bs-py-2 bs-d-flex bs-gap-3 bs-align-items-center" }) do %> 
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-trash"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                        <%= t("enterpriseStore.delete_and_uninstall") %>
                                    <% end %>
                                <% end %>
                            <% end %>
                        <% end %>
                    <% end %>
                <% end %>
                <% if @app.wingman_app && @published_to > 0 %>
                    <%= button_to store_installed_status_path(@app), method: :get, params: { release_id: @latest_release.id, page: 1, "per_page": 200, "q": "", app_type: "ent_android_app" }, data: { turbo_frame: "store_app_installed_status" }, class: "bs-btn bs-px-2 bs-fw-bold bs-text-primary automation_store_app_view_status_button" do %>
                        <%= t("enterpriseStore.publish_status") %>
                    <% end %>
                <% end %>
                <% if @app.published_device_count(current_user, @latest_release.id, false) > 0 %>
                    <%= button_to store_installed_status_path(@app), method: :get, params: { release_id: @latest_release.id, store_id: @app&.id, page: 1, "per_page": 20, "q": "", app_type: "ent_android_app" }, data: { turbo_frame: "store_app_installed_status" }, class: "bs-btn bs-px-2 bs-fw-bold bs-text-primary automation_store_app_view_status_button" do %>
                        <%= t("enterpriseStore.publish_status") %>
                    <% end %>
                <% end %>
                <% unless read_only_access('AppStore-ReadOnly') %>
                    <% if @latest_release.permissions_parsed && @latest_release.target_sdk_version.to_i >= 23 && app_type != "recommendedApps" %>
                        <% if @latest_release.apk_permissions.present? %>
                            <%= button_to user_store_store_app_permissions_path(@current_user), method: :get, params: { release_id: @latest_release.id }, data: { turbo_frame: "store_app_permissions" }, class: "bs-btn bs-px-2 bs-fw-bold bs-text-primary automation_store_app_view_permissions_button" do %>
                                <%= t("v2.emm.permissions.manage_permissions") %>
                            <% end %>
                        <% end %>
                    <% end %>
                <% end %>
                <%# Release Action %>
                <% actions.each do |action| %>
                    <%= action %>
                <% end %>
                <!-- For Wingman App -->
                <% if @app.wingman_app %>
                    <%= content_tag :p, "Description", class: "bs-m-0" %>
                    <%= content_tag :p, t("enterpriseStore.wingman_note"), class: "bs-m-0" %>
                    <%= sf "WarningMessage::", label: t("enterpriseStore.wingman_publish_note") unless current_user.admin_parent.wingman_activated %>
                <% end %>
            </div>
            <% if current_user.admin_parent.amapi_activated? %>
                <%= sf "BsModal", id: "upload-enterprise-app-amapu-setup-modal", show_header: false, title: "", backdrop: false do |c| %>
                    <%= raw t("emm.not_supported_for_amapi") %>
                    <% c.with_footer do %>
                        <button class="bs-btn bs-btn-outline-primary bs-me-3" data-bs-dismiss="bs-modal">
                            <%= t("common.ok") %>
                        </button>

                    <% end %>
                <% end %>
            <% end %>
        </div>
    </div>
</div>
<% if !@app.recommended? && !@app.wingman_app && !@app.app_mobilock? && @app.allow_previous_release?(current_user) && @previous_releases.present? %>
    <% @previous_releases.each do |release| %>
        <%
            previous_release_publish_count = @app.published_device_count(current_user, release.id)
            previous_release_install_count = previous_release_publish_count > 0 ? DeviceApp.installed_devices_count(current_user, @app.package, release.version_code, release.id) : 0
        %>
        <%= sf "Store::AppInfo::",
            app: @app,
            current_user: current_user,
            is_open: false,
            is_latest: false,
            app_version: "#{release.version_name} (#{@app.wingman_app ? "N/A" : release.version_code})",
            latest_release: release,
            installed_on: previous_release_install_count,
            previous_releases_count: @previous_releases_count,
            published_to: previous_release_publish_count do |c|%>
            <% if release.notes.nil? ? check_permission?('AppStore') : check_permission?('AppStore-ReadOnly') || check_permission?('AppStore') %>
                <% c.with_action do%>
                    <%= turbo_frame_tag "release_note_btn-#{release.id}" do %>
                        <%= button_tag({data: { bs_toggle: "modal", bs_target: "#view-release-notes-modal-#{release.id}" }, class: "automation_view_release_notes bs-btn bs-px-2 bs-fw-bold bs-text-primary"}) do %>
                            <%= release.notes.nil? ? t("enterpriseStore.addReleaseNote") : t("enterpriseStore.view_release_notes") %>
                        <% end %>
                    <% end %>
                <% end %>
            <% end %>
        <% end %>
    <% end %>
<% end %>
